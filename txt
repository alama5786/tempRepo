# Parameters
$SqlInstance = "YourSQLServerName"
$ServiceAccount = "DOMAIN\ServiceAccount"
$DurationMinutes = 60

Write-Host "Granting sysadmin access to $ServiceAccount on $SqlInstance"

# Grant sysadmin role
$grantQuery = @"
IF NOT EXISTS (
    SELECT 1 
    FROM sys.server_role_members rm
    JOIN sys.server_principals r ON rm.role_principal_id = r.principal_id
    JOIN sys.server_principals m ON rm.member_principal_id = m.principal_id
    WHERE r.name = 'sysadmin' AND m.name = '$ServiceAccount'
)
BEGIN
    ALTER SERVER ROLE [sysadmin] ADD MEMBER [$ServiceAccount]
END
"@

Invoke-Sqlcmd -ServerInstance $SqlInstance -Query $grantQuery

Write-Host "Sysadmin granted. Access will be revoked in $DurationMinutes minutes."

# Wait for defined duration
Start-Sleep -Seconds ($DurationMinutes * 60)

Write-Host "Revoking sysadmin access from $ServiceAccount"

# Revoke sysadmin role
$revokeQuery = @"
IF EXISTS (
    SELECT 1 
    FROM sys.server_role_members rm
    JOIN sys.server_principals r ON rm.role_principal_id = r.principal_id
    JOIN sys.server_principals m ON rm.member_principal_id = m.principal_id
    WHERE r.name = 'sysadmin' AND m.name = '$ServiceAccount'
)
BEGIN
    ALTER SERVER ROLE [sysadmin] DROP MEMBER [$ServiceAccount]
END
"@

Invoke-Sqlcmd -ServerInstance $SqlInstance -Query $revokeQuery

Write-Host "Sysadmin access revoked successfully."
